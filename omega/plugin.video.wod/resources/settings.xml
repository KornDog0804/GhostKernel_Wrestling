<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="3">
    <category label="Real-Debrid">
        <setting id="debrid_enabled" type="bool" label="Enable Real-Debrid" default="false" />
        <setting id="debrid_api" type="text" label="Real-Debrid API Token" default="" option="hidden" visible="eq(-1,true)" />
        <setting id="debrid_info" type="label" label="Get your API token at: https://real-debrid.com/account/credentials" visible="eq(-2,true)" />
    </category>
    
    <category label="Streaming Sources">
        <setting id="source_m3u8_enabled" type="bool" label="Enable M3U8 IPTV Playlists" default="true" />
        <setting id="m3u8_url" type="text" label="M3U8 Playlist URL" default="http://ubusercontent.com/m3u8/NETWORK.m3u8" visible="eq(-1,true)" />
        
        <setting id="source_watchwrestling24_enabled" type="bool" label="Enable watchwrestling24.net Scraping" default="true" />
        <setting id="ww24_info" type="label" label="Scrapes watchwrestling24.net for additional shows and streams" />
        
        <setting id="wwe_enabled" type="bool" label="Enable WWE" default="true" />
        <setting id="aew_enabled" type="bool" label="Enable AEW" default="true" />
        <setting id="impact_enabled" type="bool" label="Enable Impact Wrestling" default="true" />
        <setting id="njpw_enabled" type="bool" label="Enable NJPW" default="true" />
        <setting id="nxt_enabled" type="bool" label="Enable NXT" default="true" />
        <setting id="roh_enabled" type="bool" label="Enable ROH" default="true" />
    </category>
    
    <category label="Video Quality">
        <setting id="preferred_quality" type="select" label="Preferred Stream Quality" default="auto">
            <option>Auto</option>
            <option>720p</option>
            <option>1080p</option>
            <option>4K</option>
        </setting>
        <setting id="hls_streams" type="bool" label="Allow HLS/M3U8 Streams" default="true" />
        <setting id="http_streams" type="bool" label="Allow HTTP/MP4 Streams" default="true" />
    </category>
    
    <category label="Advanced">
        <setting id="debug_logging" type="bool" label="Enable Debug Logging" default="false" />
        <setting id="stream_timeout" type="slider" label="Stream Timeout (seconds)" type="int" default="30" range="10,120" option="int" />
        <setting id="cache_ttl" type="slider" label="Cache TTL (minutes)" type="int" default="60" range="5,1440" option="int" />
    </category>
    
    <category label="About">
        <setting id="about_title" type="label" label="⚔️ Ghostkernel Wrestling Hub v1.0.0" />
        <setting id="about_desc" type="label" label="WWE | AEW | NJPW | NXT | ROH" />
        <setting id="about_korndog" type="label" label="Powered by Korndog Records • DIY Spirit • Zombie Kitty Approved 🧟‍♀️" />
        <setting id="about_github" type="label" label="GitHub: KornDog0804/plugin.video.ghostkernel.wrestling" />
    </category>
</settings>
